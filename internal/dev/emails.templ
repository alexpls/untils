package dev

import (
	"github.com/alexpls/untils/internal/components"
	"github.com/alexpls/untils/internal/notifications"
)

type EmailPreviewPageData struct {
	Template notifications.EmailTemplateDefinition
	Rendered notifications.RenderedEmail
	HTMLURL  string
}

templ EmailPreviewsIndexPage(templates []notifications.EmailTemplateDefinition) {
	@components.AppLayout("Email previews", []components.Breadcrumb{
		{Title: "Dev", Href: "#noop"},
		{Title: "Email previews", Href: "/app/dev/emails"},
	}) {
		@components.Header("Email previews", nil)
		<div class="p-4 space-y-4">
			for _, tmpl := range templates {
				<div class="rounded border border-base-content/10 bg-base-100 p-4">
					<div class="flex items-center justify-between gap-4">
						<h3 class="text-lg font-semibold">{ tmpl.Name }</h3>
						<a class="btn btn-sm" href={ "/app/dev/emails/" + tmpl.Key }>Preview</a>
					</div>
				</div>
			}
		</div>
	}
}

templ EmailPreviewPage(data EmailPreviewPageData) {
	@components.AppLayout(data.Template.Name, []components.Breadcrumb{
		{Title: "Dev", Href: "#noop"},
		{Title: "Email previews", Href: "/app/dev/emails"},
		{Title: data.Template.Name, Href: "/app/dev/emails/" + data.Template.Key},
	}) {
		@components.Header(data.Template.Name, nil)
		<div class="space-y-4 p-4">
			<div class="rounded border border-base-content/10 bg-base-100 p-4">
				<div class="mb-3 text-sm text-muted">Subject</div>
				<div class="text-lg font-semibold">{ data.Rendered.Subject }</div>
			</div>
			<div class="rounded border border-base-content/10 bg-base-100 p-2">
				<iframe class="h-160 w-full rounded border-0 bg-white" src={ data.HTMLURL } title={ data.Rendered.Subject }></iframe>
			</div>
			<div class="rounded border border-base-content/10 bg-base-100 p-4">
				<div class="mb-3 text-sm text-muted">Text version</div>
				<pre class="whitespace-pre-wrap wrap-break-word text-sm">{ data.Rendered.TextBody }</pre>
			</div>
		</div>
	}
}
