# HTTP port exposed by the app container.
APP_PORT="3322"

# Public base URL used in links and callbacks.
BASE_URL="http://localhost:3322"

# Required. Whether cookies should use the Secure (HTTPS) attribute.
# WARNING: host with HTTPS and set this to true if your instance is going to be public!
SECURE_COOKIES=false

# Required. If the database is empty, this email will be used to create the first admin user.
# The initial password is abc123.
ADMIN_EMAIL=

# Required. OpenAI-compatible API key.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5.4.
OPENAI_MODEL=

# Required. Brave Search API token used for searches.
BRAVE_KEY=

# Optional. Pushover application token for push notifications.
# Leave unset to disable pushover support.
PUSHOVER_KEY=

# Optional. SMTP settings for email notifications.
# Leave unset to disable email notifications.
SMTP_FROM=notifications@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Required. Postgres settings for the bundled db service.
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=untils
DB_DATA_LOCATION=./selfhosted_pgdata

# Required. Remote Chrome DevTools endpoint used for browser-based checks.
CHROME_DEVTOOLS_URL=ws://browser:9222
